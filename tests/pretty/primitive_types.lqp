(transaction
  (configure
    { :ivm.maintenance_level "off" :optimization_level "default" :semantics_version 0})
  (epoch
    (writes
      (define
        (fragment
          :f1
          (def :int ([v::INT] (= v 21)))
          (def :int_n ([v::INT] (= v -21)))
          (def :int128_s ([v::INT128] (= v 21i128)))
          (def :int128_l ([v::INT128] (= v 85968058283706962486085i128)))
          (def :int128_n ([v::INT128] (= v -5968058283706962486085i128)))
          (def :uint128 ([v::UINT128] (= v 0x123456789abcdef12345)))
          (def :int32 ([v::INT32] (= v 42i32)))
          (def :int32_n ([v::INT32] (= v -42i32)))
          (def :uint32 ([v::UINT32] (= v 42u32)))
          (def :float32 ([v::FLOAT32] (= v 1.23f32)))
          (def :float ([v::FLOAT] (= v 1.23)))
          (def :float_inf ([v::FLOAT] (= v inf)))
          (def :float_nan ([v::FLOAT] (= v nan)))
          (def :date ([v::DATE] (= v (date 2025 8 1))))
          (def :datetime ([v::DATETIME] (= v (datetime 2025 8 1 20 3 4 123000))))
          (def :dec ([v::(DECIMAL 18 6)] (= v 123.456000d18)))
          (def :str ([v::STRING] (= v "hello")))
          (def :bool ([v::BOOLEAN] (= v true)))
          (def :output_int ([v::INT] (and (= v 21) (atom :int 21))))
          (def :output_int_n ([v::INT] (and (= v -21) (atom :int_n -21))))
          (def :output_int128_s ([v::INT128] (and (= v 21i128) (atom :int128_s 21i128))))
          (def
            :output_int128_l
            ([v::INT128]
             (and
               (= v 85968058283706962486085i128)
               (atom :int128_l 85968058283706962486085i128))))
          (def
            :output_int128_n
            ([v::INT128]
             (and
               (= v -5968058283706962486085i128)
               (atom :int128_n -5968058283706962486085i128))))
          (def
            :output_uint128
            ([v::UINT128]
             (and (= v 0x123456789abcdef12345) (atom :uint128 0x123456789abcdef12345))))
          (def :output_int32 ([v::INT32] (and (= v 42i32) (atom :int32 42i32))))
          (def :output_int32_n ([v::INT32] (and (= v -42i32) (atom :int32_n -42i32))))
          (def :output_uint32 ([v::UINT32] (and (= v 42u32) (atom :uint32 42u32))))
          (def :output_float32 ([v::FLOAT32] (and (= v 1.23f32) (atom :float32 1.23f32))))
          (def :output_float ([v::FLOAT] (and (= v 1.23) (atom :float 1.23))))
          (def :output_float_inf ([v::FLOAT] (and (= v inf) (atom :float_inf inf))))
          (def :output_float_nan ([v::FLOAT] (and (= v nan) (atom :float_nan nan))))
          (def
            :output_dec
            ([v::(DECIMAL 18 6)] (and (= v 123.456000d18) (atom :dec 123.456000d18))))
          (def
            :output_date
            ([v::DATE] (and (= v (date 2025 8 1)) (atom :date (date 2025 8 1)))))
          (def
            :output_datetime
            ([v::DATETIME]
             (and
               (= v (datetime 2025 8 1 20 3 4 123000))
               (atom :datetime (datetime 2025 8 1 20 3 4 123000)))))
          (def :output_str ([v::STRING] (and (= v "hello") (atom :str "hello"))))
          (def :output_bool ([v::BOOLEAN] (and (= v true) (atom :bool true)))))))
    (reads
      (output :int :output_int)
      (output :int_n :output_int_n)
      (output :int128_s :output_int128_s)
      (output :int128_l :output_int128_l)
      (output :int128_n :output_int128_n)
      (output :uint128 :output_uint128)
      (output :int32 :output_int32)
      (output :int32_n :output_int32_n)
      (output :uint32 :output_uint32)
      (output :float32 :output_float32)
      (output :float :output_float)
      (output :float_inf :output_float_inf)
      (output :float_nan :output_float_nan)
      (output :dec :output_dec)
      (output :date :output_date)
      (output :datetime :output_datetime)
      (output :str :output_str)
      (output :bool :output_bool))))
